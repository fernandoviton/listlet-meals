# Credentials for the scripts/ CLI tools (Node only — never served to the browser).
# Copy to .env and fill in. .env is gitignored.

# Same Project URL + publishable/anon key as config.local.js.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Obtained by running `node scripts/google-login.js` once. The CLI refreshes
# and rewrites this on each run, so leave it blank until you bootstrap.
SUPABASE_REFRESH_TOKEN=

# Optional — defaults to listlet_meals if unset.
DB_TABLE=listlet_meals
